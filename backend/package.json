{
  "name": "task-scheduler-backend",
  "version": "1.0.0",
  "description": "Intelligent Task Allocation and Scheduling System - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "ts-node src/scripts/benchmark.ts",
    "experiments": "ts-node src/scripts/run_experiments.ts",
    "experiments:energy": "ts-node src/scripts/run_experiments.ts --mode energy",
    "experiments:reliability-tasks": "ts-node src/scripts/run_experiments.ts --mode reliability-tasks",
    "experiments:reliability-tolerance": "ts-node src/scripts/run_experiments.ts --mode reliability-tolerance",
    "experiments:all": "ts-node src/scripts/run_experiments.ts --mode all",
    "simulate": "ts-node src/scripts/run_experiments.ts --mode simulate",
    "demo": "ts-node src/scripts/demo-data.ts",
    "presentation": "ts-node src/scripts/presentation.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.79.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.221.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.221.0",
    "@opentelemetry/propagator-b3": "^2.9.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "openai": "^6.34.0",
    "pdfkit": "^0.14.0",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "qs": "^6.15.2"
  }
}
